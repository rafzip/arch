cat >/etc/dinit.d/zram <<'EOF'
type = scripted
command = /bin/sh -c 'modprobe zram && echo zstd > /sys/block/zram0/comp_algorithm && echo $(($(awk "/MemTotal/{print \$2}" /proc/meminfo)*1024/2)) > /sys/block/zram0/disksize && mkswap /dev/zram0 && swapon -p 100 /dev/zram0'
EOF
ln -s /etc/dinit.d/zram /etc/dinit.d/boot.d/
